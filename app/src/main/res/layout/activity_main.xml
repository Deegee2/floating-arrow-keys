<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="#1a1a2e">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎮 Floating Arrow Keys"
        android:textSize="24sp"
        android:textColor="#e0e0e0"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Injects real keyboard events for games"
        android:textSize="14sp"
        android:textColor="#9e9e9e"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status: Hidden"
        android:textSize="16sp"
        android:textColor="#64b5f6"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnToggle"
        android:layout_width="200dp"
        android:layout_height="56dp"
        android:text="Show Floating Keys"
        android:textColor="#ffffff"
        android:backgroundTint="#3f51b5"
        android:textSize="16sp"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Instructions:"
        android:textSize="14sp"
        android:textColor="#e0e0e0"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1. Grant 'Display over other apps' permission\n2. Press 'Show Floating Keys'\n3. Drag the keyboard anywhere on screen\n4. Open your game — keys will work!"
        android:textSize="13sp"
        android:textColor="#9e9e9e"
        android:lineSpacingMultiplier="1.5"/>

</LinearLayout>
